{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "pcf": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#",
    "CarbonFootprint": {
      "@id": "pcf:CarbonFootprint",
      "@type": "@id"
    },
    "id": "@id",
    "type": "@type",
    "ProductCarbonFootprints": {
      "@id": "pcf:ProductCarbonFootprints",
      "@context": {
        "@version": 1.1,
        "id": "@id",
        "type": "@type",
        "@context": {
          "@version": 1.1,
          "id": "@id",
          "type": "@type",
          "PcfCalculationMethods": {
            "@id": "pcf:PcfCalculationMethods",
            "@context": {
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#pcfCalculationMethods",
              "@definition": "Standards, methods for determining the greenhouse gas emissions of a product."
            },
            "@container": "@list",
            "@type": "schema:string"
          },
          "PcfCo2eq": {
            "@id": "pcf:PcfCo2eq",
            "@context": {
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#pcfCo2eq",
              "@definition": "Sum of all greenhouse gas emissions of a product according to the quantification requirements of the standard."
            },
            "@type": "schema:number"
          },
          "ReferenceImpactUnitForCalculation": {
            "@id": "pcf:ReferenceImpactUnitForCalculation",
            "@context": {
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#referenceImpactUnitForCalculation",
              "@definition": "Quantity unit of the product to which the PCF information on the CO2 footprint refers."
            },
            "@type": "schema:string"
          },
          "QuantityOfMeasureForCalculation": {
            "@id": "pcf:QuantityOfMeasureForCalculation",
            "@context": {
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#quantityOfMeasureForCalculation",
              "@definition": "Provides the quantity number of pieces or mass or volume to compute the impact of climate change or product carbon footprint."
            },
            "@type": "schema:number"
          },
          "LifeCyclePhases": {
            "@id": "pcf:LifeCyclePhases",
            "@context": {
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#lifeCyclePhases",
              "@definition": "Life cycle stages of the product according to the quantification requirements of the standard to which the PCF carbon footprint statement refers."
            },
            "@container": "@list",
            "@type": "schema:string"
          },
          "ExplanatoryStatement": {
            "@id": "pcf:ExplanatoryStatement",
            "@context": {
              "@version": 1.1,
              "id": "@id",
              "type": "@type",
              "value": {
                "@id": "pcf:value",
                "@context": {
                  "@definition": "Path and name of the file (with file extension).\n\nThe path can be absolute or relative.",
                  "@samm-urn": "urn:samm:io.admin-shell.idta.shared:3.1.0#resourceValue"
                },
                "@type": "schema:string"
              },
              "contentType": {
                "@id": "pcf:contentType",
                "@context": {
                  "@definition": "Content type of the content of the file or blob.",
                  "@samm-urn": "urn:samm:io.admin-shell.idta.shared:3.1.0#contentType"
                },
                "@type": "schema:string"
              },
              "@definition": "Explanation required or provided to ensure that a footprint communication can be properly understood by a purchaser, potential purchaser, or user of the product.",
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#explanatoryStatement"
            }
          },
          "PublicationDate": {
            "@id": "pcf:PublicationDate",
            "@context": {
              "@definition": "Time at which something was first published or made available.",
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#publicationDate"
            },
            "@type": "schema:string"
          },
          "ExpirationDate": {
            "@id": "pcf:ExpirationDate",
            "@context": {
              "@definition": "End date up to which a study or data collection for calculating an ecological footprint is considered current and valid before an update or new calculation is required.",
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#expirationDate"
            },
            "@type": "schema:string"
          }
        },
        "@definition": "(Set) Balance of greenhouse gas emissions along the entire life cycle of a product in a defined application and in relation to a defined unit of use.",
        "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#productCarbonFootprints"
      },
      "@container": "@list"
    },
    "ProductOrSectorSpecificCarbonFootprints": {
      "@id": "pcf:ProductOrSectorSpecificCarbonFootprints",
      "@context": {
        "@version": 1.1,
        "id": "@id",
        "type": "@type",
        "@context": {
          "@version": 1.1,
          "id": "@id",
          "type": "@type",
          "PcfCalculationMethods": {
            "@id": "pcf:PcfCalculationMethods",
            "@context": {
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#productOrSectorSpecificPcfCalculationMethods",
              "@definition": "Standard, method for determining the greenhouse gas emissions of a product. Multiple standards can be listed in case these standards are all applied to the respective PCF calculation."
            },
            "@container": "@list",
            "@type": "schema:string"
          },
          "ProductOrSectorSpecificRule": {
            "@id": "pcf:ProductOrSectorSpecificRule",
            "@context": {
              "@version": 1.1,
              "id": "@id",
              "type": "@type",
              "PcfRuleOperator": {
                "@id": "pcf:PcfRuleOperator",
                "@context": {
                  "@definition": "Organization that defines and implements specific instructions and methods for calculating and monitoring the carbon footprint of a product or sector.",
                  "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#pcfRuleOperator"
                },
                "@type": "schema:string"
              },
              "PcfRuleName": {
                "@id": "pcf:PcfRuleName",
                "@context": {
                  "@definition": "Standard, method for determining the greenhouse gas emissions of a product.",
                  "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#pcfRuleName"
                },
                "@type": "schema:string"
              },
              "PcfRuleVersion": {
                "@id": "pcf:PcfRuleVersion",
                "@context": {
                  "@definition": "Specific version or revision of the rule used to calculate the carbon footprint of a product.",
                  "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#pcfRuleVersion"
                },
                "@type": "schema:string"
              },
              "PcfRuleOnlineReference": {
                "@id": "pcf:PcfRuleOnlineReference",
                "@context": {
                  "@version": 1.1,
                  "id": "@id",
                  "type": "@type",
                  "value": {
                    "@id": "pcf:value",
                    "@context": {
                      "@definition": "Path and name of the file (with file extension).\n\nThe path can be absolute or relative.",
                      "@samm-urn": "urn:samm:io.admin-shell.idta.shared:3.1.0#resourceValue"
                    },
                    "@type": "schema:string"
                  },
                  "contentType": {
                    "@id": "pcf:contentType",
                    "@context": {
                      "@definition": "Content type of the content of the file or blob.",
                      "@samm-urn": "urn:samm:io.admin-shell.idta.shared:3.1.0#contentType"
                    },
                    "@type": "schema:string"
                  },
                  "@definition": "Online PCF calculation methodology reference that provides detailed instructions and guidelines for calculating a product's carbon footprint.",
                  "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#pcfRuleOnlineReference"
                }
              },
              "@definition": "Contains further information on the product-specific or sector-specific rules used to calculate the carbon footprint.",
              "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#productOrSectorSpecificRule"
            }
          }
        },
        "@definition": "Product carbon footprints, which are determined in accordance with sector or product group-specific rules or guidelines and cover the life cycle or parts of a product life cycle.",
        "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#productOrSectorSpecificCarbonFootprints"
      },
      "@container": "@list"
    },
    "@definition": "Provides the means to access the Carbon Footprint of the asset.",
    "@samm-urn": "urn:samm:io.admin-shell.idta.carbon_footprint:1.0.0#CarbonFootprint"
  }
}